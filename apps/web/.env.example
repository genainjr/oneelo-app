NEXT_PUBLIC_API_URL=http://localhost:4001

# PWA / Push notifications
# O frontend nao deve receber a WEB_PUSH_PRIVATE_KEY.
# A chave publica VAPID e lida da API autenticada em /api/notifications/public-key.

# Opcional para testar o Next dev server a partir de outro dispositivo na rede local.
# Exemplo: NEXT_ALLOWED_DEV_ORIGINS=192.168.0.14
NEXT_ALLOWED_DEV_ORIGINS=
