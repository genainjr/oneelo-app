// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Prisma keeps the application contract in PT-BR while the physical database uses EN identifiers.

enum Plano {
  GRATUITO     @map("FREE")
  BASICO       @map("BASIC")
  PROFISSIONAL @map("PROFESSIONAL")

  @@map("plan")
}

enum StatusAssinatura {
  ATIVA     @map("ACTIVE")
  TRIAL
  SUSPENSA  @map("SUSPENDED")
  CANCELADA @map("CANCELLED")

  @@map("subscription_status")
}

enum Role {
  ADMIN
  STAFF
  BASIC
  SUPER_ADMIN

  @@map("role")
}

enum AuthProvider {
  GOOGLE
  APPLE

  @@map("auth_provider")
}

enum MinistryRole {
  LEADER
  ASSISTANT_LEADER
  MEMBER

  @@map("ministry_role")
}

enum StatusMembro {
  ATIVO        @map("ACTIVE")
  INATIVO      @map("INACTIVE")
  VISITANTE    @map("VISITOR")
  TRANSFERIDO  @map("TRANSFERRED")

  @@map("member_status")
}

enum StatusEscala {
  RASCUNHO  @map("DRAFT")
  PUBLICADA @map("PUBLISHED")
  ENCERRADA @map("CLOSED")

  @@map("schedule_status")
}

enum StatusConfirmacao {
  PENDENTE   @map("PENDING")
  CONFIRMADO @map("CONFIRMED")
  RECUSADO   @map("DECLINED")

  @@map("confirmation_status")
}

enum StatusEvento {
  AGENDADO  @map("SCHEDULED")
  REALIZADO @map("COMPLETED")
  CANCELADO @map("CANCELLED")

  @@map("event_status")
}

enum EventoTipo {
  GERAL
  MINISTERIO
  REUNIAO_INTERNA

  @@map("event_type")
}

enum AcaoAuditoria {
  CRIAR     @map("CREATE")
  ATUALIZAR @map("UPDATE")
  DELETAR   @map("DELETE")
  LOGIN
  LOGOUT

  @@map("audit_action")
}

model Tenant {
  id               String           @id @default(uuid())
  nome             String           @map("name")
  slug             String           @unique
  plano            Plano            @default(GRATUITO) @map("plan")
  statusAssinatura StatusAssinatura @default(TRIAL) @map("subscription_status")
  limiteMembros    Int              @default(50) @map("member_limit")
  ativo            Boolean          @default(true) @map("is_active")
  email            String?
  telefone         String?          @map("phone")
  idioma           String?          @map("language")
  logoUrl          String?          @map("logo_url")
  logoKey          String?          @map("logo_key")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  users       User[]
  membros     Membro[]
  tags        Tag[]
  ministerios Ministerio[]
  escalas     Escala[]
  eventos     Evento[]
  auditLogs   AuditLog[]
  pushSubscriptions PushSubscription[]

  @@map("tb_tenant")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String?  @map("tenant_id")
  memberId     String?  @unique @map("member_id")
  nome         String   @map("name")
  email        String   @unique
  senhaHash    String   @map("password_hash")
  role         Role     @default(BASIC)
  ativo        Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant       Tenant?      @relation(fields: [tenantId], references: [id])
  membro       Membro?      @relation(fields: [memberId], references: [id])
  escalasItens EscalaItem[]
  auditLogs    AuditLog[]
  pushSubscriptions PushSubscription[]
  authProviders UserAuthProvider[]

  @@index([tenantId])
  @@map("tb_user")
}

model UserAuthProvider {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  provider       AuthProvider
  providerUserId String       @map("provider_user_id")
  email          String?
  emailVerified  Boolean      @default(false) @map("email_verified")
  displayName    String?      @map("display_name")
  avatarUrl      String?      @map("avatar_url")
  ativo          Boolean      @default(true) @map("is_active")
  linkedAt       DateTime     @default(now()) @map("linked_at")
  lastLoginAt    DateTime?    @map("last_login_at")
  revokedAt      DateTime?    @map("revoked_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
  @@index([email])
  @@map("tb_user_auth_provider")
}

model Membro {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  nome           String       @map("name")
  nomeExibicao   String?      @map("display_name")
  whatsapp       String?      @map("mobile_phone")
  email          String?
  dataNascimento DateTime?    @map("birth_date")
  fotoUrl        String?      @map("photo_url")
  fotoKey        String?      @map("photo_key")
  status         StatusMembro @default(ATIVO) @map("member_status")
  observacoes    String?      @map("notes")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  tags        MembroTag[]
  ministerios MinisterioMembro[]
  escalas     EscalaItem[]
  user        User?

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("tb_member")
}

model Tag {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  nome     String @map("name")
  corHex   String @default("#6366f1") @map("color_hex")

  tenant  Tenant      @relation(fields: [tenantId], references: [id])
  membros MembroTag[]

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@map("tb_label")
}

model MembroTag {
  membroId String @map("member_id")
  tagId    String @map("label_id")

  membro Membro @relation(fields: [membroId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@id([membroId, tagId])
  @@map("tb_member_label")
}

model Ministerio {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  nome      String   @map("name")
  descricao String?  @map("description")
  ativo     Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant              @relation(fields: [tenantId], references: [id])
  membros MinisterioMembro[]
  escalas Escala[]
  funcoes MinisterioFuncao[]
  eventos EventoMinisterio[]

  @@index([tenantId])
  @@map("tb_ministry")
}

model MinisterioFuncao {
  id           String  @id @default(uuid())
  ministerioId String  @map("ministry_id")
  nome         String  @map("name")
  descricao    String? @map("description")
  corHex       String? @map("color_hex")
  ordem        Int     @default(0) @map("display_order")

  ministerio   Ministerio               @relation(fields: [ministerioId], references: [id])
  itens        EscalaItem[]
  membrosAptos MinisterioMembroFuncao[]
  diasOcultos  EscalaDiaFuncaoOculta[]

  @@unique([ministerioId, nome])
  @@map("tb_ministry_position")
}

model MinisterioMembro {
  ministerioId String       @map("ministry_id")
  membroId     String       @map("member_id")
  role         MinistryRole @default(MEMBER)

  ministerio         Ministerio                @relation(fields: [ministerioId], references: [id])
  membro             Membro                    @relation(fields: [membroId], references: [id])
  funcoesDisponiveis MinisterioMembroFuncao[]

  @@id([ministerioId, membroId])
  @@map("tb_ministry_member")
}

model MinisterioMembroFuncao {
  ministerioId String @map("ministry_id")
  membroId     String @map("member_id")
  funcaoId     String @map("position_id")

  ministerioMembro MinisterioMembro @relation(fields: [ministerioId, membroId], references: [ministerioId, membroId], onDelete: Cascade)
  funcao           MinisterioFuncao @relation(fields: [funcaoId], references: [id], onDelete: Cascade)

  @@id([ministerioId, membroId, funcaoId])
  @@map("tb_ministry_member_position")
}

model Escala {
  id           String       @id @default(uuid())
  tenantId     String       @map("tenant_id")
  ministerioId String       @map("ministry_id")
  mes          Int          @map("month")
  ano          Int          @map("year")
  status       StatusEscala @default(RASCUNHO) @map("schedule_status")
  observacoes  String?      @map("notes")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  ministerio Ministerio @relation(fields: [ministerioId], references: [id])
  dias       EscalaDia[]

  @@index([tenantId])
  @@unique([ministerioId, mes, ano])
  @@map("tb_schedule")
}

model EscalaDia {
  id          String   @id @default(uuid())
  escalaId    String   @map("schedule_id")
  data        DateTime @map("scheduled_date")
  titulo      String?  @map("title")
  eventoId    String?  @map("event_id")
  observacoes String?  @map("notes")
  ordem       Int      @default(0) @map("display_order")

  escala         Escala                 @relation(fields: [escalaId], references: [id], onDelete: Cascade)
  evento         Evento?                @relation(fields: [eventoId], references: [id], onDelete: SetNull)
  itens          EscalaItem[]
  funcoesOcultas EscalaDiaFuncaoOculta[]

  @@map("tb_schedule_day")
}

model EscalaDiaFuncaoOculta {
  diaId    String @map("day_id")
  funcaoId String @map("position_id")

  dia    EscalaDia        @relation(fields: [diaId], references: [id], onDelete: Cascade)
  funcao MinisterioFuncao @relation(fields: [funcaoId], references: [id], onDelete: Cascade)

  @@id([diaId, funcaoId])
  @@map("tb_schedule_day_position_hidden")
}

model EscalaItem {
  id                 String            @id @default(uuid())
  escalaDiaId        String            @map("schedule_day_id")
  membroId           String            @map("member_id")
  userId             String?           @map("user_id")
  ministerioFuncaoId String            @map("ministry_position_id")
  statusConfirmacao  StatusConfirmacao @default(PENDENTE) @map("confirmation_status")
  observacoes        String?           @map("notes")

  escalaDia EscalaDia         @relation(fields: [escalaDiaId], references: [id], onDelete: Cascade)
  membro    Membro            @relation(fields: [membroId], references: [id])
  user      User?             @relation(fields: [userId], references: [id])
  funcao    MinisterioFuncao  @relation(fields: [ministerioFuncaoId], references: [id])

  @@unique([escalaDiaId, membroId])
  @@unique([escalaDiaId, membroId, ministerioFuncaoId])
  @@map("tb_schedule_assignment")
}

model Evento {
  id         String       @id @default(uuid())
  tenantId   String       @map("tenant_id")
  titulo     String       @map("title")
  descricao  String?      @map("description")
  tipo       EventoTipo   @default(GERAL) @map("type")
  dataInicio DateTime     @map("start_at")
  dataFim    DateTime?    @map("end_at")
  local      String?      @map("location")
  status     StatusEvento @default(AGENDADO) @map("event_status")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  escalasDias EscalaDia[]
  ministerios EventoMinisterio[]

  @@index([tenantId])
  @@index([tenantId, tipo])
  @@index([tenantId, dataInicio])
  @@map("tb_event")
}

model EventoMinisterio {
  eventoId     String @map("event_id")
  ministerioId String @map("ministry_id")

  evento     Evento     @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  ministerio Ministerio @relation(fields: [ministerioId], references: [id], onDelete: Cascade)

  @@id([eventoId, ministerioId])
  @@index([ministerioId])
  @@map("tb_event_ministry")
}

model AuditLog {
  id            String        @id @default(uuid())
  tenantId      String?       @map("tenant_id")
  userId        String?       @map("user_id")
  entidade      String        @map("entity")
  entidadeId    String        @map("entity_id")
  acao          AcaoAuditoria @map("action")
  payloadBefore Json?         @map("payload_before")
  payloadAfter  Json?         @map("payload_after")
  ipAddress     String?       @map("ip_address")
  createdAt     DateTime      @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, entidade, entidadeId])
  @@map("tb_audit_log")
}

model PushSubscription {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  ativo     Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, userId, ativo])
  @@map("tb_push_subscription")
}

model Lead {
  id        String   @id @default(uuid())
  nome      String   @map("name")
  email     String
  telefone  String?  @map("phone")
  mensagem  String?  @map("message")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("tb_lead")
}
