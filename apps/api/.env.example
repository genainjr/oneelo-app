DATABASE_URL=postgresql://dev:dev@localhost:5433/oneelo_saas
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=COLOQUE_SUA_SECRET_KEY_AQUI
JWT_SECRET=change_me
JWT_EXPIRES_IN=1d

# Rollout do login por telefone e senha. Ausente ou false mantem apenas e-mail/senha.
PHONE_PASSWORD_LOGIN_ENABLED=false

# Google OAuth / Login social
# A callback deve apontar para o app web usando /api, para o cookie de login ficar no dominio do frontend.
# Exemplo local: http://localhost:3001/api/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=COLOQUE_SEU_CLIENT_ID_GOOGLE_AQUI
GOOGLE_OAUTH_CLIENT_SECRET=COLOQUE_SEU_CLIENT_SECRET_GOOGLE_AQUI
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3001/api/auth/oauth/google/callback

# Web Push / PWA notifications
# Gere com: npm.cmd run push:keys -w apps/api
# A chave publica pode ser exposta ao frontend pelo endpoint /api/notifications/public-key.
# A chave privada deve ficar somente no backend e nunca deve ser commitada.
WEB_PUSH_PUBLIC_KEY=COLOQUE_SUA_CHAVE_PUBLICA_VAPID_AQUI
WEB_PUSH_PRIVATE_KEY=COLOQUE_SUA_CHAVE_PRIVADA_VAPID_AQUI
WEB_PUSH_SUBJECT=mailto:suporte@lookuplabs.com.br

# Origens publicas do frontend permitidas pela API. A primeira origem tambem e
# usada para montar os links de ativacao enviados aos membros.
CORS_ORIGIN=http://localhost:3001
NODE_ENV=development
PORT=4001
